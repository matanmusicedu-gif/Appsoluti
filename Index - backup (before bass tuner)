    for(let j=0;j<tl-t;j++){num+=tb[j]*tb[j+t];d1+=tb[j]*tb[j];d2+=tb[j+t]*tb[j+t]}
    nsdf[t]=d1+d2>0?2*num/(d1+d2):0}
