  let T=mi;if(T>0&&T<tl-1){const a2=nsdf[T-1],b2=nsdf[T],c2=nsdf[T+1];
    const dl=(a2-c2)/(2*(a2-2*b2+c2));if(Math.abs(dl)<1)T+=dl}
