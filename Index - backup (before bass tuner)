<script>
const SN=['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'],FN=['C','Db','D','Eb','E','F','Gb','G','Ab','A','Bb','B'];
const m2f=n=>440*Math.pow(2,(n-69)/12),f2n=f=>Math.round(12*Math.log2(f/440))+69;
const cOff=(f,n)=>Math.round(1200*Math.log2(f/(440*Math.pow(2,(n-69)/12))));
const NC=['#d4a830','#6b2e8b','#b83838','#2a4888','#4488ee','#c09028','#5a2070','#993030','#1e3670','#e45090','#9050e0','#482060'];
const NCD=['#a08020','#4a1e6a','#882020','#162855','#2266cc','#806818','#381050','#701818','#0e1e48','#b03070','#6030b0','#301040'];

/* ═══ IndexedDB ═══ */
const IDB={
  open(){return new Promise((res,rej)=>{const r=indexedDB.open('appsoluti',1);r.onupgradeneeded=e=>{e.target.result.createObjectStore('tracks',{keyPath:'id',autoIncrement:true})};r.onsuccess=e=>res(e.target.result);r.onerror=e=>rej(e)})},
  async save(name,blob){const db=await this.open();return new Promise((res,rej)=>{const tx=db.transaction('tracks','readwrite');tx.objectStore('tracks').put({name,blob,date:Date.now()});tx.oncomplete=()=>res();tx.onerror=e=>rej(e)})},
  async getAll(){const db=await this.open();return new Promise((res,rej)=>{const tx=db.transaction('tracks','readonly');const r=tx.objectStore('tracks').getAll();r.onsuccess=()=>res(r.result);r.onerror=e=>rej(e)})},
  async del(id){const db=await this.open();return new Promise((res,rej)=>{const tx=db.transaction('tracks','readwrite');tx.objectStore('tracks').delete(id);tx.oncomplete=()=>res();tx.onerror=e=>rej(e)})}
};

const _AD={
  hihat_hi:"data:audio/ogg;base64,",
  hihat_lo:"data:audio/ogg;base64,",
  kick_hi:"data:audio/ogg;base64,",
  kick_lo:"data:audio/ogg;base64,",
  rim_hi:"data:audio/ogg;base64,",
  rim_lo:"data:audio/ogg;base64,",
  snap_hi:"data:audio/ogg;base64,",
  snap_lo:"data:audio/ogg;base64,",
  wood_hi:"data:audio/ogg;base64,",
  wood_lo:"data:audio/ogg;base64,",
  gtr_e6:"data:audio/ogg;base64,",
  gtr_a5:"data:audio/ogg;base64,",
  gtr_d4:"data:audio/ogg;base64,",
  gtr_g3:"data:audio/ogg;base64,",
  gtr_b2:"data:audio/ogg;base64,",
  gtr_e1:"data:audio/ogg;base64,",
};

/* ═══ AUDIO ENGINE ═══ */
const AE=(()=>{
let ctx,rvB,catB;
const g=()=>{if(!ctx||ctx.state==='closed')ctx=new(window.AudioContext||window.webkitAudioContext)();if(ctx.state==='suspended')ctx.resume();return ctx};
const rv=()=>{if(rvB)return rvB;const c=g(),l=c.sampleRate*2.5,b=c.createBuffer(2,l,c.sampleRate);
  for(let ch=0;ch<2;ch++){const d=b.getChannelData(ch);for(let i=0;i<l;i++)d[i]=(Math.random()*2-1)*Math.exp(-i/(c.sampleRate*.6))*.25}rvB=b;return b};
const catRv=()=>{if(catB)return catB;const c=g(),l=c.sampleRate*5,b=c.createBuffer(2,l,c.sampleRate);
  for(let ch=0;ch<2;ch++){const d=b.getChannelData(ch);for(let i=0;i<l;i++){const t=i/c.sampleRate;d[i]=(Math.random()*2-1)*Math.exp(-t/2.2)*.22*(1+Math.sin(t*1.3)*.15)}}catB=b;return b};

/* ── Sample buffer system ── */
const _SB={};let _SBL=false;
function _ldSamp(key,b64){
  const c=g();if(c.state==='closed')return;
  try{const bin=atob(b64.split(',')[1]);const arr=new Uint8Array(bin.length);
  for(let i=0;i<bin.length;i++)arr[i]=bin.charCodeAt(i);
  c.decodeAudioData(arr.buffer.slice(0),buf=>{_SB[key]=buf;},err=>{console.warn('decode fail',key)});}
  catch(e){console.warn('load fail',key,e);}}
function _doLoad(){Object.entries(_AD).forEach(([k,v])=>_ldSamp(k,v));}
function ensureSamps(){if(_SBL)return;_SBL=true;const c=g();
  if(c.state==='running'){_doLoad();}else{c.resume().then(_doLoad).catch(_doLoad);}}
function playSamp(key,t,vol=1){const c=g();const buf=_SB[key];if(!buf)return false;
  const s=c.createBufferSource();s.buffer=buf;const ga=c.createGain();ga.gain.value=vol;
  s.connect(ga);ga.connect(c.destination);s.start(t||c.currentTime);return true;}
/* Track currently playing guitar samples by string index */
const gtrPlayingSources={};
function stopGtrSamp(strIdx){
  if(gtrPlayingSources[strIdx]){
    try{gtrPlayingSources[strIdx].stop();}catch(e){}
    gtrPlayingSources[strIdx]=null;
  }
}
function playGtrSamp(strIdx,semitones){ensureSamps();
  stopGtrSamp(strIdx);
  const c=g();
  const keys=['gtr_e6','gtr_a5','gtr_d4','gtr_g3','gtr_b2','gtr_e1'];
  const key=keys[strIdx];const buf=_SB[key];
  if(!buf){setTimeout(()=>playGtrSamp(strIdx,semitones),200);return;}
  const s=c.createBufferSource();s.buffer=buf;
  if(semitones!==0)s.playbackRate.value=Math.pow(2,semitones/12);
  const ga=c.createGain();ga.gain.value=0.85;s.connect(ga);ga.connect(c.destination);s.start(c.currentTime);
  gtrPlayingSources[strIdx]=s;
}
const BASS_SAMPS={"0":"data:audio/ogg;base64,","1":"data:audio/ogg;base64,","2":"data:audio/ogg;base64,","3":"data:audio/ogg;base64,"};
function playBassSamp(strIdx,semitones){ensureSamps();const c=g();const keys=['0','1','2','3'];const key=keys[strIdx];const buf=_SB[key];
  if(!buf){setTimeout(()=>playBassSamp(strIdx,semitones),200);return;}
  const s=c.createBufferSource();s.buffer=buf;
  if(semitones!==0)s.playbackRate.value=Math.pow(2,semitones/12);
  const ga=c.createGain();ga.gain.value=0.85;s.connect(ga);ga.connect(c.destination);s.start(c.currentTime);}
const claves=(t,a)=>{const c=g();t=t||c.currentTime;const v=a?1:.5,fr=a?2900:2400;
  const o=c.createOscillator(),ga=c.createGain(),f=c.createBiquadFilter();o.type='sine';o.frequency.setValueAtTime(fr,t);o.frequency.exponentialRampToValueAtTime(fr*.7,t+.02);
  f.type='bandpass';f.frequency.value=fr;f.Q.value=18;ga.gain.setValueAtTime(v,t);ga.gain.exponentialRampToValueAtTime(.001,t+.07);
  o.connect(f);f.connect(ga);ga.connect(c.destination);o.start(t);o.stop(t+.08);
  if(a){const o2=c.createOscillator(),g2=c.createGain();o2.type='sine';o2.frequency.setValueAtTime(fr*1.5,t);g2.gain.setValueAtTime(.3,t);g2.gain.exponentialRampToValueAtTime(.001,t+.025);o2.connect(g2);g2.connect(c.destination);o2.start(t);o2.stop(t+.03)}};
/* click: uses real samples, falls back to claves if not loaded yet */
const _SMAP={wood:'wood',hihat:'hihat',kick:'kick',rim:'rim',snap2:'snap'};
const click=(snd,t,a)=>{
  const base=_SMAP[snd];
  if(base){ensureSamps();const k=base+'_'+(a?'hi':'lo');
    if(playSamp(k,t))return;
    /* not loaded yet – try after short delay (only for immediate preview, not scheduled) */
    if(!t||t<=g().currentTime+0.05){setTimeout(()=>playSamp(k,null),150);}
    return;}
  claves(t,a);};
const applause=()=>{const c=g(),t=c.currentTime,bl=c.sampleRate*2.5,buf=c.createBuffer(2,bl,c.sampleRate);
  for(let ch=0;ch<2;ch++){const d=buf.getChannelData(ch);for(let i=0;i<bl;i++)d[i]=(Math.random()*2-1)*Math.sin(Math.PI*i/bl)*(Math.random()>.96?.5:.07)*.4}
  const s=c.createBufferSource();s.buffer=buf;const f=c.createBiquadFilter();f.type='bandpass';f.frequency.value=3000;f.Q.value=.5;s.connect(f);f.connect(c.destination);s.start(t)};
let _pv=[],_MV=16;
function _av(ns){_pv.push({n:ns,t:Date.now()});while(_pv.length>_MV){const o=_pv.shift();o.n.forEach(x=>{try{if(x.stop)x.stop();x.disconnect()}catch(e){}})}}
const piano=(freq,dur=1.8,useRv=false)=>{const c=g(),t=c.currentTime;
  const m=c.createGain(),comp=c.createDynamicsCompressor();comp.threshold.value=-10;comp.ratio.value=3;
  m.gain.setValueAtTime(.24,t);m.gain.setValueAtTime(.2,t+.005);m.gain.exponentialRampToValueAtTime(.07,t+.25);m.gain.exponentialRampToValueAtTime(.001,t+dur);
  if(useRv){const dr=c.createGain();dr.gain.value=.6;const cv=c.createConvolver();cv.buffer=rv();const wt=c.createGain();wt.gain.value=.4;
    m.connect(comp);comp.connect(dr);dr.connect(c.destination);comp.connect(cv);cv.connect(wt);wt.connect(c.destination)}
